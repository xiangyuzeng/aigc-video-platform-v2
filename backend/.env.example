# Database (SQLite, relative to backend/)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# File storage
UPLOAD_DIR=./data/uploads
ASSETS_DIR=./data/assets
OUTPUT_DIR=./output/videos

# AdsPower
ADSPOWER_BASE_URL=http://127.0.0.1:50325
SCRAPER_PROFILE_ID=k17avugk

# AI Services — Required for content generation and video creation
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
KIE_API_KEY=
ELEVENLABS_API_KEY=

# kie.ai Video Generation
KIE_API_URL=https://api.kie.ai/api/v1
KIE_PROVIDER=veo
KIE_DEFAULT_ASPECT_RATIO=9:16
KIE_POLL_INTERVAL=10.0
KIE_POLL_TIMEOUT=300.0

# Content Generation
CONTENT_PRIMARY_LANGUAGE=en
CONTENT_TRANSLATION_LANGUAGES=["zh","es"]
CONTENT_MAX_HASHTAGS=8

# Video
VIDEO_RESOLUTION_W=1080
VIDEO_RESOLUTION_H=1920
VIDEO_FPS=30
TTS_ENGINE=edge-tts
TTS_VOICE=en-US-AriaNeural

# Pipeline
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_BASE_DELAY=1.0

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
DEFAULT_TIMEZONE=America/Mexico_City
