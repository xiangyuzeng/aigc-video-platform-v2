# ============================================================
# AIGC 视频发布平台 — 环境变量配置
# ============================================================
# 使用方法：
#   cp .env.example .env    （然后编辑 .env 填入你的密钥）
#
# Docker 用户：AdsPower 地址已自动处理，无需修改
# ============================================================

# ---------- 数据库 ----------
# SQLite 数据库路径（相对于 backend 目录）
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ---------- 文件存储 ----------
# 上传的视频文件存放目录
UPLOAD_DIR=./data/uploads
# 静态资源目录
ASSETS_DIR=./data/assets
# AI 生成的视频输出目录
OUTPUT_DIR=./output/videos

# ---------- AdsPower 反检测浏览器 ----------
# AdsPower 本地 API 地址（打开 AdsPower 后自动运行在此端口）
# 本地开发：http://127.0.0.1:50325
# Docker 内：http://host.docker.internal:50325（docker-compose 已自动覆盖）
ADSPOWER_BASE_URL=http://127.0.0.1:50325
# 数据采集用的浏览器环境 ID（在 AdsPower 中查看）
SCRAPER_PROFILE_ID=YOUR_PROFILE_ID

# ---------- AI 服务密钥（必填） ----------
# Anthropic Claude — 用于文案生成
# 获取地址：https://console.anthropic.com/ → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
# Claude 模型名称
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — 用于图片生成（可选，不填则跳过图片功能）
# 获取地址：https://platform.openai.com/ → API Keys
OPENAI_API_KEY=sk-YOUR_KEY_HERE

# kie.ai — 用于 AI 视频生成（必填）
# 获取地址：https://kie.ai/ → 注册 → 控制台 → API Key
KIE_API_KEY=YOUR_KIE_KEY_HERE

# ElevenLabs — 高级语音合成（可选）
ELEVENLABS_API_KEY=

# ---------- kie.ai 视频生成参数 ----------
# API 端点（一般不需要修改）
KIE_API_URL=https://api.kie.ai/api/v1
# 视频生成模型提供商（veo = Google Veo3）
KIE_PROVIDER=veo
# 视频比例（9:16 = 竖屏，适合 TikTok/抖音）
KIE_DEFAULT_ASPECT_RATIO=9:16
# 轮询间隔和超时（秒）
KIE_POLL_INTERVAL=10.0
KIE_POLL_TIMEOUT=300.0

# ---------- 内容生成 ----------
# 主要语言（生成文案的语言）
CONTENT_PRIMARY_LANGUAGE=en
# 翻译目标语言（JSON 数组）
CONTENT_TRANSLATION_LANGUAGES=["zh","es"]
# 每条文案最大标签数
CONTENT_MAX_HASHTAGS=8

# ---------- 视频参数 ----------
# 分辨率（1080x1920 = 竖屏全高清）
VIDEO_RESOLUTION_W=1080
VIDEO_RESOLUTION_H=1920
VIDEO_FPS=30
# 语音合成引擎（edge-tts 免费，无需密钥）
TTS_ENGINE=edge-tts
# 语音角色（参考 edge-tts --list-voices 查看可用角色）
TTS_VOICE=en-US-AriaNeural

# ---------- 流水线 ----------
# 任务失败后最大重试次数
PIPELINE_MAX_RETRIES=3
# 重试间隔基数（秒，实际间隔会指数递增）
PIPELINE_RETRY_BASE_DELAY=1.0

# ---------- 服务器 ----------
HOST=0.0.0.0
PORT=8000
# 允许的前端地址（CORS 跨域）
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
# 排期使用的时区
DEFAULT_TIMEZONE=America/Mexico_City
